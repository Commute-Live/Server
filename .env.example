POSTGRES_DB=commutelive
POSTGRES_USER=commute
POSTGRES_PASSWORD=commute
POSTGRES_PORT_BIND=5432
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT_BIND}/${POSTGRES_DB}
STAGING_DATABASE_URL=
PROD_DATABASE_URL=
TRANSIT_BACKUP_DIR=/home/your-user/transit-backups/commute-live
REDIS_PORT_BIND=6379
REDIS_URL=redis://localhost:6379

API_PORT_BIND=8080

MQTT_HOST=localhost
MQTT_PORT_BIND=1883
MQTT_PORT=1883
MQTT_USERNAME=commutelive
MQTT_PASSWORD=commutelive
MQTT_PROTOCOL=mqtt

# Admin query page basic auth (for GET /admin/db)
DB_ADMIN_USERNAME=
DB_ADMIN_PASSWORD=

JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-another-long-random-secret
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
COOKIE_SECURE=false
CORS_ORIGINS=http://localhost:8081,http://127.0.0.1:8081
APP_BASE_URL=https://commutelive.com
RESEND_API_KEY=
EMAIL_FROM_AUTH=Commutelive <auth@commutelive.com>
EMAIL_REPLY_TO=team@commutelive.com

# Shared secret for load-test traffic (leave blank to disable guard)
LOADTEST_SECRET_KEY=replace-with-long-random-secret

DD_ENV=dev
DD_VERSION=local
DD_LOGS_INJECTION=true
DD_SITE=us5.datadoghq.com
DD_API_KEY=
DD_HOSTNAME=commutelive-prod

# Transit provider keys
OPEN511_API_KEY=

# NJ Transit realtime credentials
NJT_API_USERNAME=
NJT_API_PASSWORD=

# Optional NJ Transit endpoint overrides
NJT_RAIL_TOKEN_URL=
NJT_RAIL_TRIP_UPDATES_URL=
NJT_BUS_TOKEN_URL=
NJT_BUS_TRIP_UPDATES_URL=
